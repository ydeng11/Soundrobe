{
  "name": "auto-tagger",
  "version": "0.1.0",
  "description": "Desktop audio tag editor",
  "author": "Auto Tagger Contributors",
  "license": "MIT",
  "homepage": "https://github.com/ihelio/auto-tagger",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tauri build",
    "build:web": "tsc && vite build",
    "dist": "tauri build",
    "dist:mac": "tauri build --bundles dmg",
    "dist:win": "tauri build --bundles nsis",
    "dist:linux": "tauri build --bundles appimage,deb",
    "preview": "vite preview",
    "test": "npm run test:web && npm run test:rust",
    "test:web": "vitest run test/components test/state test/shared test/utils test/package-scripts.test.ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:watch": "vitest test/components test/state test/shared test/utils",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
