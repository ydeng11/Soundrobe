{
  "name": "soundrobe",
  "version": "0.1.0",
  "description": "Desktop audio tag editor",
  "author": "Soundrobe Contributors",
  "license": "MIT",
  "homepage": "https://github.com/ydeng11/Soundrobe",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tauri build",
    "build:web": "tsc && vite build",
    "build:e2e": "tauri build --no-bundle --features wdio --config src-tauri/tauri.wdio.conf.json",
    "dist": "tauri build",
    "dist:mac": "tauri build --bundles app,dmg",
    "dist:win": "tauri build --bundles nsis",
    "dist:linux": "tauri build --bundles appimage,deb",
    "preview": "vite preview",
    "test": "npm run test:web && npm run test:rust",
    "test:web": "vitest run test/components test/state test/shared test/utils test/package-scripts.test.ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "npm run build:e2e && wdio run wdio.conf.ts",
    "test:watch": "vitest test/components test/state test/shared test/utils",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/native-utils": "^2.5.0",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@wdio/native-utils": "$@wdio/native-utils",
    "serialize-javascript": "7.0.7"
  }
}
